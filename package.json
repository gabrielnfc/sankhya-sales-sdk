{
  "name": "sankhya-sales-sdk",
  "version": "1.0.0",
  "description": "SDK TypeScript para APIs comerciais do Sankhya ERP (vendas B2B)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "test:integration": "vitest run tests/integration/",
    "test:smoke": "tsup && node tests/smoke/cjs.cjs && node tests/smoke/esm.mjs",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build && npx publint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "sankhya",
    "erp",
    "sdk",
    "api",
    "b2b",
    "vendas"
  ],
  "author": "Gabriel Nascimento",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielnfc/sankhya-sales-sdk.git"
  }
}
